# Copy this file to .env on the ECS server and fill real values.
# Do not commit .env.

# Public frontend build setting. "/" means browser requests the same origin, e.g. https://example.com/api.
VITE_API_BASE_URL=/
HTTP_PORT=80

# Spring Boot
SPRING_PROFILES_ACTIVE=prod
SERVER_PORT=8080
STORY2SCRIPT_CORS_ALLOWED_ORIGINS=https://www.example.com,https://example.com

# PostgreSQL. If PostgreSQL is installed on the same ECS host, host.docker.internal works with Docker Desktop
# but usually not Linux Engine. Prefer the ECS private IP, RDS internal endpoint, or a Docker network hostname.
DATABASE_URL=jdbc:postgresql://<postgres-host>:5432/story2script
DATABASE_USERNAME=story2script
DATABASE_PASSWORD=<change-me>

# OpenAI-compatible chat provider.
# Used by the main conversion/agent model configured with OPENAI_MODEL.
# The input assistant currently uses the same provider/key and a code-fixed gpt-5.4-mini model.
OPENAI_BASE_URL=https://api.openai.com
OPENAI_API_KEY=<change-me>
OPENAI_MODEL=gpt-4.1-mini
OPENAI_MAX_TOKENS=4096

# Auth. Use at least 32 random characters for AUTH_TOKEN_SECRET.
AUTH_TOKEN_SECRET=<change-me-at-least-32-random-characters>
REGISTRATION_INVITE_CODE=<change-me>
AUTH_TOKEN_TTL_SECONDS=604800

# Keep true when users visit the site over HTTPS. For temporary HTTP smoke tests only, set false.
AUTH_COOKIE_SECURE=true

# First production launch: keep RAG/vector search disabled unless pgvector and DashScope are ready.
# When disabled, DASHSCOPE_* embedding settings below are not required.
STORY2SCRIPT_RAG_VECTOR_STORE_ENABLED=false
STORY2SCRIPT_RAG_SYNC_ON_STARTUP=false
SPRING_AI_MODEL_EMBEDDING=none
SPRING_AI_VECTORSTORE_TYPE=none

# Enable only when using pgvector + DashScope embeddings.
# This is the second provider family, used only for embedding/vector search.
# STORY2SCRIPT_RAG_VECTOR_STORE_ENABLED=true
# STORY2SCRIPT_RAG_SYNC_ON_STARTUP=true
# SPRING_AI_MODEL_EMBEDDING=openai
# SPRING_AI_VECTORSTORE_TYPE=pgvector
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# DASHSCOPE_API_KEY=<change-me>
# DASHSCOPE_EMBEDDING_MODEL=text-embedding-v4
# DASHSCOPE_EMBEDDING_DIMENSIONS=1024
